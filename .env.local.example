# ─────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk sends users after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Clerk webhook secret — set in Clerk dashboard → Webhooks
# Events to subscribe: user.created, user.updated
CLERK_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Supabase — https://supabase.com/dashboard
# ─────────────────────────────────────────────

# Prisma uses the pooled connection string (port 6543) for queries
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Prisma uses the direct connection (port 5432) for migrations
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────
# Encryption — for AccessKey.encryptedValue
# Generate with: openssl rand -base64 32
# ─────────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-base64-secret-here

# ─────────────────────────────────────────────
# Cron — protects /api/cron/* routes
# Generate with: openssl rand -hex 32
# Set this in Vercel dashboard → Environment Variables too
# ─────────────────────────────────────────────
CRON_SECRET=your-cron-secret-here
